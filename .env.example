# --- BLINDAGEM DE DESENVOLVEDOR ---
# AVISO: NUNCA compartilhe este arquivo ou envie chaves reais para o Git/GitHub.
# Use o menu de 'Settings' do AI Studio para gerenciar estas chaves de forma segura.

# --- CONFIGURAÇÃO DO STRIPE (MUITO IMPORTANTE) ---
# Se trocar estas duas, o sistema possui "Auto-Correção", mas tente manter a ordem:

# 1. CHAVE SECRETA (Inicia com sk_): Coloque no campo STRIPE_SECRET_KEY
#    AVISO: NUNCA mostre esta chave para ninguém.
STRIPE_SECRET_KEY=

# 2. CHAVE PÚBLICA (Inicia com pk_): Coloque no campo VITE_STRIPE_PUBLISHABLE_KEY
VITE_STRIPE_PUBLISHABLE_KEY=

# Gemini API Key (Gerenciada automaticamente no ambiente)
GEMINI_API_KEY=

# Seguranca: Todos os dados sao criptografados em repouso e em transito.
